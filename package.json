{
  "name": "zano-nova",
  "version": "2.7.0",
  "description": "Zano Nova — Zano Without the Blockchain Wait.",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/run-dev.js",
    "pack": "node scripts/run-builder.js --mode=pack",
    "pack:win": "node scripts/run-builder.js --mode=pack --win",
    "pack:mac": "node scripts/run-builder.js --mode=pack --mac",
    "pack:linux": "node scripts/run-builder.js --mode=pack --linux",
    "dist": "node scripts/run-builder.js",
    "dist:win": "node scripts/run-builder.js --win",
    "dist:mac": "node scripts/run-builder.js --mac",
    "dist:linux": "node scripts/run-builder.js --linux",
    "prepare-simplewallet": "node scripts/prepare-simplewallet.js",
    "prepare-zano:mac": "node scripts/prepare-zano-macos.js",
    "build-icon": "node scripts/build-icon.js",
    "bump": "npm version patch --no-git-tag-version"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.2",
    "sharp": "^0.33.5",
    "to-ico": "^1.0.1"
  }
}
