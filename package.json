{
  "name": "zano-nova",
  "version": "1.0.0",
  "description": "Zano Nova — Zano Without the Blockchain Wait.",
  "main": "main\\main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "node scripts/prepare-simplewallet.js && electron-builder",
    "prepare-simplewallet": "node scripts/prepare-simplewallet.js",
    "build-icon": "node scripts/build-icon.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.33.5",
    "to-ico": "^1.0.1"
  },
  "build": {
    "appId": "org.zano.simplewallet.light",
    "productName": "Zano Nova",
    "files": [
      "main/**",
      "renderer/**",
      "assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
