{
  "extends": "./build/config/electron-builder.base.json",
  "win": {
    "icon": "assets/icon.ico",
    "extraResources": [
      {
        "from": "build/vendor/simplewallet-win",
        "to": "resources",
        "filter": [
          "simplewallet.exe",
          "*.dll"
        ]
      }
    ],
    "target": [
      "nsis",
      "portable"
    ]
  },
  "nsis": {
    "installerIcon": "assets/icon.ico",
    "uninstallerIcon": "assets/icon.ico",
    "installerHeaderIcon": "assets/icon.ico",
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
